# ============================================================
# .env.example
# Environment Configuration File
#
# WHAT IS AN .env FILE?
# =====================
# An .env file stores settings/secrets that should NOT be
# hardcoded in your Python code.
# 
# Examples of things to put in .env:
# - Redis host/port
# - Secret keys
# - Database paths
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env
# 2. Edit .env with your actual values
# 3. Never commit .env to git! (Add to .gitignore)
# ============================================================

# ---- Server Settings ----
HOST=0.0.0.0
PORT=8000
DEBUG=true

# ---- Database ----
# Path where the SQLite database file will be created
DATABASE_PATH=adaptive_engine.db

# ---- Redis (optional) ----
# If Redis is not running, the app automatically uses in-memory cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_TIMEOUT=2

# ---- Security Settings ----
# How suspicious before flagging (0.0 to 1.0)
CHEAT_ALERT_THRESHOLD=0.6

# ---- AI Model Settings ----
# Which sentence-transformer model to use
# Options: 
#   all-MiniLM-L6-v2 (fast, small, good quality)
#   all-mpnet-base-v2 (slower, larger, better quality)
SIMILARITY_MODEL=all-MiniLM-L6-v2
